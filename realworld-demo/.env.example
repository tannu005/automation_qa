# ============================================================
# .env.example — Copy this to .env.local (local dev) or
# set these as environment variables on your hosting platform
# ============================================================

# -------------------------------------------------------------
# VITE_API_URL
# The backend RealWorld API base URL.
#
# In DEVELOPMENT mode this is IGNORED — MirageJS intercepts
# all API calls and serves fake data locally (no backend needed).
#
# In PRODUCTION (npm run build) this URL is used for real API calls.
#
# Options:
#   https://api.realworld.show/api   ← Active public RealWorld backend
#   https://api.conduit.io/api       ← Alternative mirror (if available)
#   http://localhost:3000/api        ← If you self-host the backend locally
# -------------------------------------------------------------
VITE_API_URL=https://api.realworld.show/api

# -------------------------------------------------------------
# VITE_APP_TITLE  (optional)
# Controls the app name shown in browser tab.
# Defaults to "Conduit" if not set.
# -------------------------------------------------------------
VITE_APP_TITLE=Conduit
